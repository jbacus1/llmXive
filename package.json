{
  "name": "llmxive",
  "version": "1.0.0",
  "description": "llmXive - Automated Scientific Discovery Platform",
  "type": "module",
  "main": "src/core/UnifiedGitHubClient.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "http-server web -p 8080 --cors",
    "build": "rollup -c",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "dompurify": "^3.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^8.50.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.3",
    "rollup": "^4.0.2"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"],
    "moduleNameMapping": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/web/"
    ]
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "jest": true
    },
    "extends": ["eslint:recommended"],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "no-console": ["warn", { "allow": ["warn", "error"] }]
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "printWidth": 100
  },
  "keywords": [
    "automation",
    "research", 
    "ai",
    "github",
    "collaboration",
    "scientific-discovery"
  ],
  "author": "ContextLab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ContextLab/llmXive.git"
  },
  "bugs": {
    "url": "https://github.com/ContextLab/llmXive/issues"
  },
  "homepage": "https://contextlab.github.io/llmXive/"
}