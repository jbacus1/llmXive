Thumbs.db

# Data security - NEVER commit raw data
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/temp/*
!data/temp/.gitkeep

# Sensitive configuration
.env.local
.env.production
*.pem
*.key
*.crt

# Logs
*.log
logs/

# Build artifacts
dist/
build/
*.egg-info/

# Test coverage
htmlcov/
.coverage
coverage.xml