# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs (except ELBO logs)
*.log
!logs/elbo/*.log
logs/*.log

# Data — all raw + processed datasets are regenerable from
# code/data/download_datasets.py; never committed.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/raw/.checksums.sha256
!data/raw/checksums.txt
!data/raw/README.md
!data/processed/README.md

# State (checksums should be tracked, but large files not)
state/projects/*.yaml

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Jupyter
*.ipynb_checkpoints

# Config with sensitive data
.env
.env.local
